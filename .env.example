# ─── Admin Authentication ──────────────────────────────
# Generate with:  npx tsx scripts/gen-password.ts
# IMPORTANT: The password hash MUST be quoted because the $ signs
# in bcrypt hashes are interpreted by Next.js dotenv-expand.
ADMIN_PASSWORD_HASH="$2b$12$...your-bcrypt-hash-here"
JWT_SECRET="your-random-secret-at-least-32-characters"

# ─── CloudBase (optional, for cloud deployment) ────────
# TCB_ENV_ID="your-cloudbase-env-id"
# TCB_SECRET_ID="your-secret-id"
# TCB_SECRET_KEY="your-secret-key"
